{
  "manifestVersion": 2,
  "id": "dev.bluepants.borgwarehouse",
  "title": "Borg Warehouse",
  "author": "Shaun Sundquist <support@bluepants.dev>",
  "description": "file://DESCRIPTION.md",
  "tagline": "Web UI for BorgBackup repositories",
  "changelog": "file://VersionHistory.md",
  "version": "3.1.2-1.3",
  "healthCheckPath": "/",
  "httpPort": 3000,
  "tcpPorts": {
    "SSH_SERVER_PORT": {
      "title": "SSH Port",
      "description": "SSH endpoint used by Borg clients",
      "defaultValue": 2222,
      "containerPort": 22,
      "enabledByDefault": true
    }
  },
  "addons": {
    "localstorage": {}
  },
  "website": "https://bluepants.dev",
  "contactEmail": "support@bluepants.dev",
  "icon": "logo.png",
  "tags": ["backup", "borg", "storage", "ssh"],
  "mediaLinks": [],
  "minBoxVersion": "7.0.0"
}
