# ══════════════════════════════════════════════════════════════════════════════
# deployment.config — Deployment configuration for Cloudron app
# ══════════════════════════════════════════════════════════════════════════════

# Docker registry configuration
# The registry URL where the Docker image is pushed
# Format: <registry-host>/<image-name>
REGISTRY_IMAGE_BASE="registry.korpit.net/borgwarehouse"

# Default app location for one-click deployment
# This is used when deploying after a successful build
# Format: <subdomain>.<domain>
# Leave empty to prompt user during build
DEFAULT_APP_LOCATION=""

# Registry credentials (optional)
# If your registry requires authentication, set these
# REGISTRY_USERNAME=""
# REGISTRY_PASSWORD=""
